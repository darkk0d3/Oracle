// firestore.rules
// Deploy these from the Firebase Console → Firestore → Rules tab
// or using Firebase CLI: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own data only
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Emergency reports: anyone authenticated can create; all can read
    match /emergencyReports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false; // Only admin via console
    }

    // Station statuses: read-only for all; write only by admin (set via console)
    match /stationStatuses/{stationId} {
      allow read: if true;
      allow write: if false;
    }

    // Feedback: authenticated users can create; no read
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }
  }
}
